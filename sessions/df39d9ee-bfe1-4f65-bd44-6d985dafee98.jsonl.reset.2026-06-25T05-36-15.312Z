[2mconn\\u001b[22m=\\u001b[90m3826177b…1e9f\\u001b[39m \\u001b[2mid\\u001b[22m=\\u001b[90m61fbd1ac…2163\\u001b[39m\",\"_meta\":{\"runtime\":\"node\",\"runtimeVersion\":\"24.14.0\",\"hostname\":\"codespaces-89e7b3\",\"name\":\"{\\\"subsystem\\\":\\\"gateway/ws\\\"}\",\"parentNames\":[\"openclaw\"],\"date\":\"2026-06-24T15:09:07.642Z\",\"logLevelId\":3,\"logLevelName\":\"INFO\",\"path\":{\"fullFilePath\":\"file:///usr/local/share/nvm/versions/node/v24.14.0/lib/node_modules/openclaw/dist/subsystem-BTVUlTIB.js:179:14\",\"fileName\":\"subsystem-BTVUlTIB.js\",\"fileNameWithLine\":\"subsystem-BTVUlTIB.js:179\",\"fileColumn\":\"14\",\"fileLine\":\"179\",\"filePath\":\"/usr/local/share/nvm/versions/node/v24.14.0/lib/node_modules/openclaw/dist/subsystem-BTVUlTIB.js\",\"filePathWithLine\":\"/usr/local/share/nvm/versions/node/v24.14.0/lib/node_modules/openclaw/dist/subsystem-BTVUlTIB.js:179\",\"method\":\"logToFile\"}},\"time\":\"2026-06-24T15:09:07.642+00:00\",\"hostname\":\"codespaces-89e7b3\",\"message\":\"\\u001b[93m⇄\\u001b[39m \\u001b[1mres\\u001b[22m \\u001b[92m✓\\u001b[39m \\u001b[1mmodels.authStatus\\u001b[22m \\u001b[2m72ms\\u001b[22m \\u001b[2mconn\\u001b[22m=\\u001b[90m3826177b…1e9f\\u001b[39m \\u001b[2mid\\u001b[22m=\\u001b[90m61fbd1ac…2163\\u001b[39m\",\"traceId\":\"8bc550c235ccc012d48e7a3221b84c15\",\"spanId\":\"0cc09c7e962883b0\",\"traceFlags\":\"01\"}\n{\"0\":\"{\\\"subsystem\\\":\\\"gateway\\\"}\",\"1\":\"provider auth state pre-warmed in 2154ms eventLoopMax=18.5ms\",\"_meta\":{\"runtime\":\"node\",\"runtimeVersion\":\"24.14.0\",\"hostname\":\"codespaces-89e7b3\",\"name\":\"{\\\"subsystem\\\":\\\"gateway\\\"}\",\"parentNames\":[\"openclaw\"],\"date\":\"2026-06-24T15:09:10.455Z\",\"logLevelId\":3,\"logLevelName\":\"INFO\",\"path\":{\"fullFilePath\":\"file:///usr/local/share/nvm/versions/node/v24.14.0/lib/node_modules/openclaw/dist/subsystem-BTVUlTIB.js:179:14\",\"fileName\":\"subsystem-BTVUlTIB.js\",\"fileNameWithLine\":\"subsystem-BTVUlTIB.js:179\",\"fileColum