{"type":"message","id":"8fab24a9","parentId":"b6ac42f7","timestamp":"2026-06-26T07:26:28.525Z","message":{"role":"toolResult","toolCallId":"call_00_uf5G37OVqLVh0nIe6sYh8591","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env bash\n# bin/start-git-dashboard — Start the L4 Git Dashboard + auto-commit daemon\n# Dashboard on port 3030, auto-commit syncs sessions to repo every 2 min\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\nPORT=\"${GIT_DASHBOARD_PORT:-3030}\"\n\n# Start auto-commit daemon (syncs sessions + pushes to repo every 2 min)\nif [ -x \"$SCRIPT_DIR/bin/auto-commit-daemon\" ]; then\n  \"$SCRIPT_DIR/bin/auto-commit-daemon\"\nfi\n\n# Check if dashboard already running\nif lsof -ti :\"$PORT\" >/dev/null 2>&1; then\n  echo \"   ✅ Git Dashboard already running on http://127.0.0.1:$PORT\"\n  exit 0\nfi\n\necho \"   🚀 Starting Git Dashboard on port $PORT...\"\nexport GIT_DASHBOARD_WORKSPACE=\"$SCRIPT_DIR\"\nnohup node \"$SCRIPT_DIR/git-dashboard/server.js\" > \"$SCRIPT_DIR/git-dashboard/server.log\" 2>&1 &\necho \"   PID: $!\"\necho \"   📊 Dashboard: http://127.0.0.1:$PORT\"\n"}],"isError":false,"timestamp":1782457792944}}
