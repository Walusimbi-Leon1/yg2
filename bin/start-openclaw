#!/usr/bin/env bash
set -euo pipefail

# Start OpenClaw Gateway
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
echo "🤖 OpenClaw: checking..."

# ── Ensure session storage lives in workspace for git tracking ──
# On a fresh codespace (OpenClaw never started), symlink sessions into workspace
# On subsequent starts, the dir/symlink already exists — skip
SESSIONS_DIR="$HOME/.openclaw/agents/main/sessions"
WORKSPACE_SESSIONS="$SCRIPT_DIR/sessions"
if [ -L "$SESSIONS_DIR" ]; then
  # Already a symlink — nothing to do
  :
elif [ -d "$SESSIONS_DIR" ]; then
  # Real directory exists — migrate to symlink (new codespace after migration)
  echo "  🔄 Migrating sessions directory to symlink..."
  cp -a "$SESSIONS_DIR/." "$WORKSPACE_SESSIONS/" 2>/dev/null || true
  rm -rf "$SESSIONS_DIR"
  ln -sf "$WORKSPACE_SESSIONS" "$SESSIONS_DIR"
  echo "  ✅ Migrated: ~/.openclaw/agents/main/sessions -> workspace/sessions/"
else
  # Does not exist — fresh codespace, create symlink
  mkdir -p "$(dirname "$SESSIONS_DIR")"
  mkdir -p "$WORKSPACE_SESSIONS"
  ln -sf "$WORKSPACE_SESSIONS" "$SESSIONS_DIR"
  echo "  🔗 Session storage linked to workspace/sessions/ — transcripts will be tracked in git"
fi

if curl -sf http://127.0.0.1:18789/health >/dev/null 2>&1; then
  echo "  ✅ OpenClaw Gateway already running"
else
  echo "  Starting OpenClaw Gateway..."
  # Copy latest config if needed
  if [ -f "$SCRIPT_DIR/openclaw-config.json" ]; then
    cp "$SCRIPT_DIR/openclaw-config.json" ~/.openclaw/openclaw.json
    echo "  Config synced from workspace"
  fi
  openclaw gateway start 2>/dev/null || openclaw gateway run --port 18789 --bind loopback &>/tmp/openclaw-gateway.log &
  sleep 3
  if curl -sf http://127.0.0.1:18789/health >/dev/null 2>&1; then
    echo "  ✅ OpenClaw Gateway running on port 18789"
  else
    echo "  ⚠️  Gateway may still be starting... check /tmp/openclaw-gateway.log"
  fi
fi
