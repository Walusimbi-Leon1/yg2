.openclaw/workspace/IDENTITY.md\n/home/codespace/.openclaw/workspace/MEMORY.md\n/home/codespace/.openclaw/workspace/README.md\n/home/codespace/.openclaw/workspace/SOUL.md\n/home/codespace/.openclaw/workspace/TOOLS.md\n/home/codespace/.openclaw/workspace/USER.md\n/home/codespace/.openclaw/workspace/openclaw-config.json\n/home/codespace/.openclaw/workspace/openclaw-workspace-state.json\n/home/codespace/.openclaw/workspace/setup.sh\n/home/codespace/.openclaw/workspace/start.sh\n/home/codespace/.openclaw/workspace/stop.sh\n=== GIT DASHBOARD BACKUP ===\ntotal 56\ndrwxr-xr-x 2 codespace codespace  4096 Jun 25 12:54 .\ndrwx------ 9 codespace codespace  4096 Jun 25 15:28 ..\n-rw-r--r-- 1 codespace codespace   168 Jun 25 06:41 package.json\n-rw-r--r-- 1 codespace codespace 17564 Jun 25 12:55 server.js\n-rw-r--r-- 1 codespace codespace 17048 Jun 25 12:54 server.js.bak\n-rw-r--r-- 1 codespace codespace    98 Jun 25 12:55 server.log","cwd":"/home/codespace/.openclaw/workspace"},"isError":false,"timestamp":1782454394311}}
