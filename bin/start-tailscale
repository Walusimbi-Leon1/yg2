#!/usr/bin/env bash
set -euo pipefail

# Start Tailscale - install if needed, start daemon, bring up connection
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
echo "🔗 Tailscale: checking..."

# Start tailscaled if not running
if ! pgrep -x tailscaled >/dev/null 2>&1; then
  echo "  Starting tailscaled..."
  sudo tailscaled --state=/var/lib/tailscale/tailscaled.state &>/dev/null &
  sleep 2
fi

# Bring up tailscale
if ! tailscale status --peers=false >/dev/null 2>&1; then
  echo "  Authenticating Tailscale..."
  echo "  ⚠️  You may need to authenticate at: https://login.tailscale.com"
  sudo tailscale up --accept-routes
else
  echo "  ✅ Tailscale is connected ($(tailscale status --peers=false | head -1 | awk '{print $1}'))"
fi
