#!/usr/bin/env bash
# bin/start-browser — Start Docker Chromium with remote streaming + CDP
# Streams on port 3001 (web UI), CDP on port 9223
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
CONTAINER_NAME="l4-browser"
BROWSER_PORT="${BROWSER_PORT:-3001}"
CDP_PORT="${CDP_PORT:-9223}"
VNC_PASSWORD="${VNC_PASSWORD:-changeme}"

echo "🖥️  Remote Browser: checking..."

# ── Helper: check if container is running ──
is_running() {
  docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^$CONTAINER_NAME$"
}

# ── Helper: check if container exists (stopped) ──
is_existing() {
  docker ps -a --format '{{.Names}}' 2>/dev/null | grep -q "^$CONTAINER_NAME$"
}

# ── If already running, show status ──
if is_running; then
  echo "   ✅ Browser is already running"
  echo "   🌐 Stream:  http://127.0.0.1:$BROWSER_PORT"
  echo "   🔌 CDP:     http://127.0.0.1:$CDP_PORT"
  exit 0
fi

# ── If stopped/exists, remove it ──
if is_existing; then
  echo "   ♻️  Removing old container..."
  docker rm "$CONTAINER_NAME" >/dev/null 2>&1
fi

# ── Ensure the config directory exists with right perms ──
mkdir -p "$SCRIPT_DIR/browser/config"

# ── Ensure chrome-remote-interface is installed ──
if [ ! -d "$SCRIPT_DIR/browser/node_modules" ]; then
  echo "   📦 Installing browser CLI dependencies..."
  cd "$SCRIPT_DIR/browser"
  npm install --silent 2>&1 | tail -1
  cd "$SCRIPT_DIR"
fi

echo "   🚀 Starting browser container..."

# ── Check if the linuxserver/chromium image exists ──
if ! docker images --format '{{.Repository}}' 2>/dev/null | grep -q "linuxserver/chromium"; then
  echo "   📥 Pulling linuxserver/chromium image (first time)..."
  docker pull linuxserver/chromium:latest
fi

# ── Run the container ──
docker run -d \
  --name "$CONTAINER_NAME" \
  --hostname "l4-browser" \
  --restart unless-stopped \
  --shm-size=2gb \
  -p "$BROWSER_PORT:3000" \
  -p "$CDP_PORT:9222" \
  -e TITLE="L4 Remote Browser" \
  -e CHROME_CLI="--remote-debugging-port=9222 --no-first-run --disable-features=TranslateUI --disable-translate --disable-fre --disable-search-engine-choice-screen" \
  -e DISPLAY_HEIGHT=720 \
  -e DISPLAY_WIDTH=1280 \
  -e DISPLAY_DPI=96 \
  -e PUID=1000 \
  -e PGID=1000 \
  -e LC_ALL=en_US.UTF-8 \
  -e CUSTOM_PORT="$BROWSER_PORT" \
  -v "$SCRIPT_DIR/browser/config:/config:rw" \
  linuxserver/chromium:latest 2>&1

echo ""
echo "   ⏳ Waiting for browser to be ready (CDP)..."
for i in $(seq 1 30); do
  if curl -sf "http://127.0.0.1:$CDP_PORT/json/version" >/dev/null 2>&1; then
    echo "   ✅ Browser ready!"
    echo ""
    echo "   ── Connection Info ──────────────────"
    echo "   🌐 Web UI:  http://127.0.0.1:$BROWSER_PORT"
    echo "              (password: $VNC_PASSWORD)"
    echo "   🔌 CDP:     http://127.0.0.1:$CDP_PORT"
    echo "   🔧 CLI:     cd $SCRIPT_DIR/browser && node browser.js status"
    echo "   ─────────────────────────────────────"
    exit 0
  fi
  sleep 2
done

echo "   ⚠️  Browser started but CDP not yet available. Check:"
echo "      docker logs $CONTAINER_NAME"
echo "   The web UI may still work at http://127.0.0.1:$BROWSER_PORT"
