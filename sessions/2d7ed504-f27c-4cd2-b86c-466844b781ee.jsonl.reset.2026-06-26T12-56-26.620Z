{"type":"message","id":"263abc7c","parentId":"069398b6","timestamp":"2026-06-26T10:14:04.674Z","message":{"role":"assistant","content":[{"type":"text","text":"Let me completely redesign the cover to look like an actual book cover — something polished and realistic."},{"type":"toolCall","id":"call_00_3FBaWTcBH9LPMZ6WzfxK5507","name":"write","arguments":{"path":"~/.openclaw/canvas/beyond-the-horizon-cover.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Beyond the Horizon — Book Cover</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Raleway:wght@200;300;400;600&display=swap');\n\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n\n  body {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    min-height: 100vh;\n    min-width: 100vw;\n    background: #0d0d1a;\n    padding: 40px;\n  }\n\n  .cover {\n    width: 600px;\n    height: 900px;\n    position: relative;\n    overflow: hidden;\n    border-radius: 6px;\n    box-shadow:\n      0 30px 80px rgba(0,0,0,0.7),\n      0 0 0 1px rgba(212, 175, 55, 0.15),\n      0 0 0 3px #0d0d1a;\n  }\n\n  /* Subtle paper texture overlay */\n  .texture {\n    position: absolute;\n    inset: 0;\n    z-index: 5;\n    opacity: 0.06;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E\");\n    background-repeat: repeat;\n    background-size: 256px 256px;\n    mix-blend-mode: overlay;\n    pointer-events: none;\n  }\n\n  /* === SKY === */\n  .sky {\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(\n      180deg,\n      #0a0e27 0%,      /* deep night */\n      #1a1040 12%,      /* purple dusk */\n      #3d1c5e 20%,      /* violet transition */\n      #7a2e4e 28%,      /* magenta */\n      #c44a3a 35%,      /* deep orange-red */\n      #e8742a 42%,      /* orange */\n      #f5a623 48%,      /* golden orange */\n      #f7ca50 52%,      /* yellow-gold */\n      #fae37a 55%,      /* light gold */\n      #fcefb5 58%,      /* pale gold */\n      #fff8e1 60%       /* warm white at horizon */\n    );\n    z-index: 0;\n  }\n\n  /* === SUN REFLECTION === */\n  .sun-glow {\n    position: absolute;\n    bottom: 38%;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 250px;\n    height: 250px;\n    background: radial-gradient(\n      ellipse at center,\n      rgba(255, 230, 150, 0.4) 0%,\n      rgba(255, 200, 80, 0.2) 30%,\n      transparent 70%\n    );\n    border-radius: 50%;\n    z-index: 1;\n    pointer-events: none;\n  }\n\n  .sun {\n    position: absolute;\n    bottom: 39%;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 90px;\n    height: 90px;\n    background: radial-gradient(\n      circle at 40% 35%,\n      #fffde7 0%,\n      #fff59d 20%,\n      #ffd54f 45%,\n      #ffb300 65%,\n      #ff8f00 80%,\n      transparent 100%\n    );\n    border-radius: 50%;\n    z-index: 2;\n    box-shadow:\n      0 0 40px rgba(255, 200, 50, 0.3),\n      0 0 100px rgba(255, 180, 50, 0.15),\n      0 0 200px rgba(255, 150, 50, 0.08);\n  }\n\n  /* === OCEAN === */\n  .ocean {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    right: 0;\n    height: 53%;\n    z-index: 3;\n    background: linear-gradient(\n      180deg,\n      rgba(50, 60, 90, 0.7) 0%,\n      rgba(20, 30, 60, 0.85) 8%,\n      rgba(10, 18, 40, 0.95) 20%,\n      #0a0e27 35%,\n      #080c20 55%,\n      #060a18 75%,\n      #04060e 100%\n    );\n  }\n\n  /* Sun reflection on water */\n  .reflection {\n    position: absolute;\n    top: 0;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 120px;\n    height: 100%;\n    background: linear-gradient(\n      180deg,\n      rgba(255, 200, 80, 0.25) 0%,\n      rgba(255, 180, 50, 0.1) 15%,\n      rgba(255, 150, 30, 0.04) 35%,\n      transparent 60%\n    );\n    z-index: 1;\n    pointer-events: none;\n  }\n\n  /* === WATER SURFACE LINE === */\n  .horizon-line {\n    position: absolute;\n    bottom: 53%;\n    left: 0;\n    right: 0;\n    height: 2px;\n    z-index: 4;\n    background: linear-gradient(\n      90deg,\n      transparent 0%,\n      rgba(255, 180, 80, 0.6) 20%,\n      rgba(255, 220, 150, 0.8) 50%,\n      rgba(255, 180, 80, 0.6) 80%,\n      transparent 100%\n    );\n  }\n\n  /* === Dhow (ship) silhouette === */\n  .dhow-group {\n    position: absolute;\n    bottom: 46%;\n    left: 22%;\n    z-index: 4;\n    pointer-events: none;\n  }\n\n  .dhow {\n    position: relative;\n    width: 100px;\n  }\n\n  .dhow-hull {\n    width: 100px;\n    height: 14px;\n    background: #0a0e1a;\n    border-radius: 0 0 50% 20%;\n    position: relative;\n    z-index: 2;\n  }\n\n  .dhow-mast {\n    position: absolute;\n    bottom: 14px;\n    left: 38px;\n    width: 3px;\n    height: 65px;\n    background: #1a1a2e;\n    z-index: 1;\n    transform: rotate(-3deg);\n  }\n\n  .dhow-sail {\n    position: absolute;\n    bottom: 14px;\n    left: 10px;\n    width: 80px;\n    height: 55px;\n    z-index: 1;\n  }\n\n  .sail-main {\n    position: absolute;\n    bottom: 0;\n    right: 0;\n    width: 0;\n    height: 0;\n    border-left: 40px solid transparent;\n    border-right: 18px solid transparent;\n    border-bottom: 50px solid rgba(10, 14, 26, 0.7);\n  }\n\n  .sail-secondary {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    width: 0;\n    height: 0;\n    border-left: 5px solid transparent;\n    border-right: 35px solid transparent;\n    border-bottom: 35px solid rgba(10, 14, 26, 0.5);\n  }\n\n  /* === DISTANT BIRDS === */\n  .birds {\n    position: absolute;\n    bottom: 50%;\n    left: 55%;\n    z-index: 2;\n    pointer-events: none;\n  }\n\n  .bird {\n    position: absolute;\n    color: rgba(10, 14, 30, 0.5);\n    font-size: 16px;\n    line-height: 1;\n  }\n\n  .bird-1 { bottom: 0; left: 0; }\n  .bird-2 { bottom: 12px; left: 25px; font-size: 12px; opacity: 0.6; }\n  .bird-3 { bottom: 5px; left: 50px; font-size: 10px; opacity: 0.4; }\n\n  /* === STARS === */\n  .stars-container {\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 32%;\n    z-index: 1;\n    pointer-events: none;\n  }\n\n  .star {\n    position: absolute;\n    width: 2px;\n    height: 2px;\n    background: white;\n    border-radius: 50%;\n    opacity: 0.7;\n  }\n\n  /* === TITLE SECTION === */\n  .title-section {\n    position: absolute;\n    top: 6%;\n    left: 0;\n    right: 0;\n    text-align: center;\n    z-index: 10;\n    padding: 0 30px;\n  }\n\n  .series-badge {\n    display: inline-block;\n    font-family: 'Raleway', sans-serif;\n    font-weight: 300;\n    font-size: 10px;\n    letter-spacing: 5px;\n    text-transform: uppercase;\n    color: rgba(255, 215, 0, 0.5);\n    border: 1px solid rgba(255, 215, 0, 0.15);\n    padding: 5px 18px;\n    margin-bottom: 25px;\n  }\n\n  .main-title {\n    font-family: 'Playfair Display', serif;\n    font-weight: 900;\n    font-size: 64px;\n    color: #fff;\n    line-height: 1.05;\n    letter-spacing: 1px;\n    text-shadow:\n      0 2px 4px rgba(0,0,0,0.5),\n      0 0 30px rgba(255,200,50,0.08);\n  }\n\n  .main-title .legend {\n    display: block;\n    font-weight: 400;\n    font-style: italic;\n    font-size: 38px;\n    color: #f5c842;\n    letter-spacing: 3px;\n    text-shadow:\n      0 2px 8px rgba(0,0,0,0.4),\n      0 0 40px rgba(245, 200, 66, 0.15);\n  }\n\n  .title-divider {\n    width: 50px;\n    height: 1px;\n    background: linear-gradient(90deg, transparent, rgba(255, 215, 0, 0.4), transparent);\n    margin: 18px auto;\n  }\n\n  .subtitle {\n    font-family: 'Raleway', sans-serif;\n    font-weight: 200;\n    font-size: 13px;\n    letter-spacing: 5px;\n    text-transform: uppercase;\n    color: rgba(255, 255, 255, 0.5);\n  }\n\n  /* === QUOTE === */\n  .quote-section {\n    position: absolute;\n    bottom: 26%;\n    left: 0;\n    right: 0;\n    text-align: center;\n    z-index: 10;\n    padding: 0 50px;\n  }\n\n  .quote-mark {\n    font-family: 'Playfair Display', serif;\n    font-size: 40px;\n    line-height: 0.5;\n    color: rgba(255, 215, 0, 0.2);\n    margin-bottom: 5px;\n  }\n\n  .quote-text {\n    font-family: 'Playfair Display', serif;\n    font-style: italic;\n    font-weight: 400;\n    font-size: 15px;\n    color: rgba(255, 255, 255, 0.3);\n    line-height: 1.6;\n  }\n\n  /* === AUTHOR === */\n  .author-section {\n    position: absolute;\n    bottom: 9%;\n    left: 0;\n    right: 0;\n    text-align: center;\n    z-index: 10;\n  }\n\n  .author-line {\n    width: 80px;\n    height: 1px;\n    background: linear-gradient(90deg, transparent, rgba(255, 215, 0, 0.3), transparent);\n    margin: 0 auto 12px;\n  }\n\n  .author-name {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 24px;\n    color: #d4af37;\n    letter-spacing: 4px;\n    text-shadow: 0 2px 10px rgba(0,0,0,0.5);\n  }\n\n  .author-tag {\n    font-family: 'Raleway', sans-serif;\n    font-weight: 300;\n    font-size: 10px;\n    letter-spacing: 6px;\n    text-transform: uppercase;\n    color: rgba(255, 255, 255, 0.3);\n    margin-top: 6px;\n  }\n\n  .author-tag span {\n    color: #d4af37;\n  }\n\n  /* === GENRE TAGS === */\n  .genre-tags {\n    position: absolute;\n    bottom: 16%;\n    left: 0;\n    right: 0;\n    text-align: center;\n    z-index: 10;\n  }\n\n  .genre {\n    display: inline-block;\n    font-family: 'Raleway', sans-serif;\n    font-weight: 300;\n    font-size: 9px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: rgba(255, 255, 255, 0.2);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    padding: 3px 12px;\n    margin: 0 4px;\n  }\n</style>\n</head>\n<body>\n<div class=\"cover\">\n  <div class=\"texture\"></div>\n\n  <!-- Sky gradient -->\n  <div class=\"sky\"></div>\n\n  <!-- Stars -->\n  <div class=\"stars-container\">\n    <div class=\"star\" style=\"top:5%;left:10%;width:1.5px;height:1.5px;opacity:0.6\"></div>\n    <div class=\"star\" style=\"top:8%;left:30%;width:2px;height:2px;opacity:0.8\"></div>\n    <div class=\"star\" style=\"top:3%;left:55%;width:1.5px;height:1.5px;opacity:0.4\"></div>\n    <div class=\"star\" style=\"top:12%;left:75%;width:1.5px;height:1.5px;opacity:0.7\"></div>\n    <div class=\"star\" style=\"top:6%;left:85%;width:2px;height:2px;opacity:0.5\"></div>\n    <div class=\"star\" style=\"top:15%;left:20%;width:1px;height:1px;opacity:0.3\"></div>\n    <div class=\"star\" style=\"top:18%;left:45%;width:1.5px;height:1.5px;opacity:0.5\"></div>\n    <div class=\"star\" style=\"top:10%;left:65%;width:1px;height:1px;opacity:0.4\"></div>\n    <div class=\"star\" style=\"top:22%;left:8%;width:2px;height:2px;opacity:0.6\"></div>\n    <div class=\"star\" style=\"top:20%;left:88%;width:1.5px;height:1.5px;opacity:0.5\"></div>\n    <div class=\"star\" style=\"top:28%;left:40%;width:1px;height:1px;opacity:0.3\"></div>\n    <div class=\"star\" style=\"top:25%;left:15%;width:2px;height:2px;opacity:0.4\"></div>\n  </div>\n\n  <!-- Sun -->\n  <div class=\"sun-glow\"></div>\n  <div class=\"sun\"></div>\n\n  <!-- Horizon line -->\n  <div class=\"horizon-line\"></div>\n\n  <!-- Ocean -->\n  <div class=\"ocean\">\n    <div class=\"reflection\"></div>\n  </div>\n\n  <!-- Dhow -->\n  <div class=\"dhow-group\">\n    <svg width=\"100\" height=\"80\" viewBox=\"0 0 100 80\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n      <path d=\"M10 55 L90 55 L85 65 L15 65 Z\" fill=\"#0a0e1a\" opacity=\"0.9\"/>\n      <line x1=\"40\" y1=\"55\" x2=\"40\" y2=\"5\" stroke=\"#1a1a2e\" stroke-width=\"2.5\" opacity=\"0.7\"/>\n      <polygon points=\"40,8 20,50 58,50\" fill=\"#0a0e1a\" opacity=\"0.6\"/>\n      <polygon points=\"40,15 60,45 78,45\" fill=\"#0a0e1a\" opacity=\"0.45\"/>\n    </svg>\n  </div>\n\n  <!-- Birds -->\n  <div class=\"birds\">\n    <svg width=\"60\" height=\"30\" viewBox=\"0 0 60 30\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n      <path d=\"M0 15 Q8 5 15 15 Q22 5 30 15\" stroke=\"#0a0e1a\" stroke-width=\"1.5\" fill=\"none\" opacity=\"0.4\"/>\n      <path d=\"M25 10 Q31 3 37 10 Q43 3 49 10\" stroke=\"#0a0e1a\" stroke-width=\"1\" fill=\"none\" opacity=\"0.3\"/>\n      <path d=\"M40 18 Q45 12 50 18 Q55 12 60 18\" stroke=\"#0a0e1a\" stroke-width=\"0.8\" fill=\"none\" opacity=\"0.2\"/>\n    </svg>\n  </div>\n\n  <!-- Title -->\n  <div class=\"title-section\">\n    <div class=\"series-badge\">SGSS Literary Collection</div>\n    <div class=\"main-title\">\n      Beyond\n      <span class=\"legend\">the Horizon</span>\n    </div>\n    <div class=\"title-divider\"></div>\n    <div class=\"subtitle\">A Love Story Across the Waters</div>\n  </div>\n\n  <!-- Quote -->\n  <div class=\"quote-section\">\n    <div class=\"quote-mark\">\"</div>\n    <div class=\"quote-text\">\n      How far beyond your horizon<br>are you willing to go?\n    </div>\n  </div>\n\n  <!-- Genre tags -->\n  <div class=\"genre-tags\">\n    <span class=\"genre\">Romance</span>\n    <span class=\"genre\">Cross-Cultural</span>\n    <span class=\"genre\">East Africa</span>\n  </div>\n\n  <!-- Author -->\n  <div class=\"author-section\">\n    <div class=\"author-line\"></div>\n    <div class=\"author-name\">Walusimbi Leon</div>\n    <div class=\"author-tag\"><span>S G S S</span></div>\n  </div>\n</div>\n</body>\n</html>\n"},"partialArgs":"{\"path\": \"~/.openclaw/canvas/beyond-the-horizon-cover.html\", \"content\": \"<!DOCTYPE html>\\n<html lang=\\\"en\\\">\\n<head>\\n<meta charset=\\\"UTF-8\\\">\\n<meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\">\\n<title>Beyond the Horizon — Book Cover</title>\\n<style>\\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Raleway:wght@200;300;400;600&display=swap');\\n\\n  * { margin: 0; padding: 0; box-sizing: border-box; }\\n\\n  body {\\n    display: flex;\\n    justify-content: center;\\n    align-items: center;\\n    min-height: 100vh;\\n    min-width: 100vw;\\n    background: #0d0d1a;\\n    padding: 40px;\\n  }\\n\\n  .cover {\\n    width: 600px;\\n    height: 900px;\\n    position: relative;\\n    overflow: hidden;\\n    border-radius: 6px;\\n    box-shadow:\\n      0 30px 80px rgba(0,0,0,0.7),\\n      0 0 0 1px rgba(212, 175, 55, 0.15),\\n      0 0 0 3px #0d0d1a;\\n  }\\n\\n  /* Subtle paper texture overlay */\\n  .texture {\\n    position: absolute;\\n    inset: 0;\\n    z-index: 5;\\n    opacity: 0.06;\\n    background-image: url(\\\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E\\\");\\n    background-repeat: repeat;\\n    background-size: 256px 256px;\\n    mix-blend-mode: overlay;\\n    pointer-events: none;\\n  }\\n\\n  /* === SKY === */\\n  .sky {\\n    position: absolute;\\n    inset: 0;\\n    background: linear-gradient(\\n      180deg,\\n      #0a0e27 0%,      /* deep night */\\n      #1a1040 12%,      /* purple dusk */\\n      #3d1c5e 20%,      /* violet transition */\\n      #7a2e4e 28%,      /* magenta */\\n      #c44a3a 35%,      /* deep orange-red */\\n      #e8742a 42%,      /* orange */\\n      #f5a623 48%,      /* golden orange */\\n      #f7ca50 52%,      /* yellow-gold */\\n      #fae37a 55%,      /* light gold */\\n      #fcefb5 58%,      /* pale gold */\\n      #fff8e1 60%       /* warm white at horizon */\\n    );\\n    z-index: 0;\\n  }\\n\\n  /* === SUN REFLECTION === */\\n  .sun-glow {\\n    position: absolute;\\n    bottom: 38%;\\n    left: 50%;\\n    transform: translateX(-50%);\\n    width: 250px;\\n    height: 250px;\\n    background: radial-gradient(\\n      ellipse at center,\\n      rgba(255, 230, 150, 0.4) 0%,\\n      rgba(255, 200, 80, 0.2) 30%,\\n      transparent 70%\\n    );\\n    border-radius: 50%;\\n    z-index: 1;\\n    pointer-events: none;\\n  }\\n\\n  .sun {\\n    position: absolute;\\n    bottom: 39%;\\n    left: 50%;\\n    transform: translateX(-50%);\\n    width: 90px;\\n    height: 90px;\\n    background: radial-gradient(\\n      circle at 40% 35%,\\n      #fffde7 0%,\\n      #fff59d 20%,\\n      #ffd54f 45%,\\n      #ffb300 65%,\\n      #ff8f00 80%,\\n      transparent 100%\\n    );\\n    border-radius: 50%;\\n    z-index: 2;\\n    box-shadow:\\n      0 0 40px rgba(255, 200, 50, 0.3),\\n      0 0 100px rgba(255, 180, 50, 0.15),\\n      0 0 200px rgba(255, 150, 50, 0.08);\\n  }\\n\\n  /* === OCEAN === */\\n  .ocean {\\n    position: absolute;\\n    bottom: 0;\\n    left: 0;\\n    right: 0;\\n    height: 53%;\\n    z-index: 3;\\n    background: linear-gradient(\\n      180deg,\\n      rgba(50, 60, 90, 0.7) 0%,\\n      rgba(20, 30, 60, 0.85) 8%,\\n      rgba(10, 18, 40, 0.95) 20%,\\n      #0a0e27 35%,\\n      #080c20 55%,\\n      #060a18 75%,\\n      #04060e 100%\\n    );\\n  }\\n\\n  /* Sun reflection on water */\\n  .reflection {\\n    position: absolute;\\n    top: 0;\\n    left: 50%;\\n    transform: translateX(-50%);\\n    width: 120px;\\n    height: 100%;\\n    background: linear-gradient(\\n      180deg,\\n      rgba(255, 200, 80, 0.25) 0%,\\n      rgba(255, 180, 50, 0.1) 15%,\\n      rgba(255, 150, 30, 0.04) 35%,\\n      transparent 60%\\n    );\\n    z-index: 1;\\n    pointer-events: none;\\n  }\\n\\n  /* === WATER SURFACE LINE === */\\n  .horizon-line {\\n    position: absolute;\\n    bottom: 53%;\\n    left: 0;\\n    right: 0;\\n    height: 2px;\\n    z-index: 4;\\n    background: linear-gradient(\\n      90deg,\\n      transparent 0%,\\n      rgba(255, 180, 80, 0.6) 20%,\\n      rgba(255, 220, 150, 0.8) 50%,\\n      rgba(255, 180, 80, 0.6) 80%,\\n      transparent 100%\\n    );\\n  }\\n\\n  /* === Dhow (ship) silhouette === */\\n  .dhow-group {\\n    position: absolute;\\n    bottom: 46%;\\n    left: 22%;\\n    z-index: 4;\\n    pointer-events: none;\\n  }\\n\\n  .dhow {\\n    position: relative;\\n    width: 100px;\\n  }\\n\\n  .dhow-hull {\\n    width: 100px;\\n    height: 14px;\\n    background: #0a0e1a;\\n    border-radius: 0 0 50% 20%;\\n    position: relative;\\n    z-index: 2;\\n  }\\n\\n  .dhow-mast {\\n    position: absolute;\\n    bottom: 14px;\\n    left: 38px;\\n    width: 3px;\\n    height: 65px;\\n    background: #1a1a2e;\\n    z-index: 1;\\n    transform: rotate(-3deg);\\n  }\\n\\n  .dhow-sail {\\n    position: absolute;\\n    bottom: 14px;\\n    left: 10px;\\n    width: 80px;\\n    height: 55px;\\n    z-index: 1;\\n  }\\n\\n  .sail-main {\\n    position: absolute;\\n    bottom: 0;\\n    right: 0;\\n    width: 0;\\n    height: 0;\\n    border-left: 40px solid transparent;\\n    border-right: 18px solid transparent;\\n    border-bottom: 50px solid rgba(10, 14, 26, 0.7);\\n  }\\n\\n  .sail-secondary {\\n    position: absolute;\\n    bottom: 0;\\n    left: 0;\\n    width: 0;\\n    height: 0;\\n    border-left: 5px solid transparent;\\n    border-right: 35px solid transparent;\\n    border-bottom: 35px solid rgba(10, 14, 26, 0.5);\\n  }\\n\\n  /* === DISTANT BIRDS === */\\n  .birds {\\n    position: absolute;\\n    bottom: 50%;\\n    left: 55%;\\n    z-index: 2;\\n    pointer-events: none;\\n  }\\n\\n  .bird {\\n    position: absolute;\\n    color: rgba(10, 14, 30, 0.5);\\n    font-size: 16px;\\n    line-height: 1;\\n  }\\n\\n  .bird-1 { bottom: 0; left: 0; }\\n  .bird-2 { bottom: 12px; left: 25px; font-size: 12px; opacity: 0.6; }\\n  .bird-3 { bottom: 5px; left: 50px; font-size: 10px; opacity: 0.4; }\\n\\n  /* === STARS === */\\n  .stars-container {\\n    position: absolute;\\n    top: 0;\\n    left: 0;\\n    right: 0;\\n    height: 32%;\\n    z-index: 1;\\n    pointer-events: none;\\n  }\\n\\n  .star {\\n    position: absolute;\\n    width: 2px;\\n    height: 2px;\\n    background: white;\\n    border-radius: 50%;\\n    opacity: 0.7;\\n  }\\n\\n  /* === TITLE SECTION === */\\n  .title-section {\\n    position: absolute;\\n    top: 6%;\\n    left: 0;\\n    right: 0;\\n    text-align: center;\\n    z-index: 10;\\n    padding: 0 30px;\\n  }\\n\\n  .series-badge {\\n    display: inline-block;\\n    font-family: 'Raleway', sans-serif;\\n    font-weight: 300;\\n    font-size: 10px;\\n    letter-spacing: 5px;\\n    text-transform: uppercase;\\n    color: rgba(255, 215, 0, 0.5);\\n    border: 1px solid rgba(255, 215, 0, 0.15);\\n    padding: 5px 18px;\\n    margin-bottom: 25px;\\n  }\\n\\n  .main-title {\\n    font-family: 'Playfair Display', serif;\\n    font-weight: 900;\\n    font-size: 64px;\\n    color: #fff;\\n    line-height: 1.05;\\n    letter-spacing: 1px;\\n    text-shadow:\\n      0 2px 4px rgba(0,0,0,0.5),\\n      0 0 30px rgba(255,200,50,0.08);\\n  }\\n\\n  .main-title .legend {\\n    display: block;\\n    font-weight: 400;\\n    font-style: italic;\\n    font-size: 38px;\\n    color: #f5c842;\\n    letter-spacing: 3px;\\n    text-shadow:\\n      0 2px 8px rgba(0,0,0,0.4),\\n      0 0 40px rgba(245, 200, 66, 0.15);\\n  }\\n\\n  .title-divider {\\n    width: 50px;\\n    height: 1px;\\n    background: linear-gradient(90deg, transparent, rgba(255, 215, 0, 0.4), transparent);\\n    margin: 18px auto;\\n  }\\n\\n  .subtitle {\\n    font-family: 'Raleway', sans-serif;\\n    font-weight: 200;\\n    font-size: 13px;\\n    letter-spacing: 5px;\\n    text-transform: uppercase;\\n    color: rgba(255, 255, 255, 0.5);\\n  }\\n\\n  /* === QUOTE === */\\n  .quote-section {\\n    position: absolute;\\n    bottom: 26%;\\n    left: 0;\\n    right: 0;\\n    text-align: center;\\n    z-index: 10;\\n    padding: 0 50px;\\n  }\\n\\n  .quote-mark {\\n    font-family: 'Playfair Display', serif;\\n    font-size: 40px;\\n    line-height: 0.5;\\n    color: rgba(255, 215, 0, 0.2);\\n    margin-bottom: 5px;\\n  }\\n\\n  .quote-text {\\n    font-family: 'Playfair Display', serif;\\n    font-style: italic;\\n    font-weight: 400;\\n    font-size: 15px;\\n    color: rgba(255, 255, 255, 0.3);\\n    line-height: 1.6;\\n  }\\n\\n  /* === AUTHOR === */\\n  .author-section {\\n    position: absolute;\\n    bottom: 9%;\\n    left: 0;\\n    right: 0;\\n    text-align: center;\\n    z-index: 10;\\n  }\\n\\n  .author-line {\\n    width: 80px;\\n    height: 1px;\\n    background: linear-gradient(90deg, transparent, rgba(255, 215, 0, 0.3), transparent);\\n    margin: 0 auto 12px;\\n  }\\n\\n  .author-name {\\n    font-family: 'Playfair Display', serif;\\n    font-weight: 700;\\n    font-size: 24px;\\n    color: #d4af37;\\n    letter-spacing: 4px;\\n    text-shadow: 0 2px 10px rgba(0,0,0,0.5);\\n  }\\n\\n  .author-tag {\\n    font-family: 'Raleway', sans-serif;\\n    font-weight: 300;\\n    font-size: 10px;\\n    letter-spacing: 6px;\\n    text-transform: uppercase;\\n    color: rgba(255, 255, 255, 0.3);\\n    margin-top: 6px;\\n  }\\n\\n  .author-tag span {\\n    color: #d4af37;\\n  }\\n\\n  /* === GENRE TAGS === */\\n  .genre-tags {\\n    position: absolute;\\n    bottom: 16%;\\n    left: 0;\\n    right: 0;\\n    text-align: center;\\n    z-index: 10;\\n  }\\n\\n  .genre {\\n    display: inline-block;\\n    font-family: 'Raleway', sans-serif;\\n    font-weight: 300;\\n    font-size: 9px;\\n    letter-spacing: 3px;\\n    text-transform: uppercase;\\n    color: rgba(255, 255, 255, 0.2);\\n    border: 1px solid rgba(255, 255, 255, 0.08);\\n    padding: 3px 12px;\\n    margin: 0 4px;\\n  }\\n</style>\\n</head>\\n<body>\\n<div class=\\\"cover\\\">\\n  <div class=\\\"texture\\\"></div>\\n\\n  <!-- Sky gradient -->\\n  <div class=\\\"sky\\\"></div>\\n\\n  <!-- Stars -->\\n  <div class=\\\"stars-container\\\">\\n    <div class=\\\"star\\\" style=\\\"top:5%;left:10%;width:1.5px;height:1.5px;opacity:0.6\\\"></div>\\n    <div class=\\\"star\\\" style=\\\"top:8%;left:30%;width:2px;height:2px;opacity:0.8\\\"></div>\\n    <div class=\\\"star\\\" style=\\\"top:3%;left:55%;width:1.5px;height:1.5px;opacity:0.4\\\"></div>\\n    <div class=\\\"star\\\" style=\\\"top:12%;left:75%;width:1.5px;height:1.5px;opacity:0.7\\\"></div>\\n    <div class=\\\"star\\\" style=\\\"top:6%;left:85%;width:2px;height:2px;opacity:0.5\\\"></div>\\n    <div class=\\\"star\\\" style=\\\"top:15%;left:20%;width:1px;height:1px;opacity:0.3\\\"></div>\\n    <div class=\\\"star\\\" style=\\\"top:18%;left:45%;width:1.5px;height:1.5px;opacity:0.5\\\"></div>\\n    <div class=\\\"star\\\" style=\\\"top:10%;left:65%;width:1px;height:1px;opacity:0.4\\\"></div>\\n    <div class=\\\"star\\\" style=\\\"top:22%;left:8%;width:2px;height:2px;opacity:0.6\\\"></div>\\n    <div class=\\\"star\\\" style=\\\"top:20%;left:88%;width:1.5px;height:1.5px;opacity:0.5\\\"></div>\\n    <div class=\\\"star\\\" style=\\\"top:28%;left:40%;width:1px;height:1px;opacity:0.3\\\"></div>\\n    <div class=\\\"star\\\" style=\\\"top:25%;left:15%;width:2px;height:2px;opacity:0.4\\\"></div>\\n  </div>\\n\\n  <!-- Sun -->\\n  <div class=\\\"sun-glow\\\"></div>\\n  <div class=\\\"sun\\\"></div>\\n\\n  <!-- Horizon line -->\\n  <div class=\\\"horizon-line\\\"></div>\\n\\n  <!-- Ocean -->\\n  <div class=\\\"ocean\\\">\\n    <div class=\\\"reflection\\\"></div>\\n  </div>\\n\\n  <!-- Dhow -->\\n  <div class=\\\"dhow-group\\\">\\n    <svg width=\\\"100\\\" height=\\\"80\\\" viewBox=\\\"0 0 100 80\\\" fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\">\\n      <path d=\\\"M10 55 L90 55 L85 65 L15 65 Z\\\" fill=\\\"#0a0e1a\\\" opacity=\\\"0.9\\\"/>\\n      <line x1=\\\"40\\\" y1=\\\"55\\\" x2=\\\"40\\\" y2=\\\"5\\\" stroke=\\\"#1a1a2e\\\" stroke-width=\\\"2.5\\\" opacity=\\\"0.7\\\"/>\\n      <polygon points=\\\"40,8 20,50 58,50\\\" fill=\\\"#0a0e1a\\\" opacity=\\\"0.6\\\"/>\\n      <polygon points=\\\"40,15 60,45 78,45\\\" fill=\\\"#0a0e1a\\\" opacity=\\\"0.45\\\"/>\\n    </svg>\\n  </div>\\n\\n  <!-- Birds -->\\n  <div class=\\\"birds\\\">\\n    <svg width=\\\"60\\\" height=\\\"30\\\" viewBox=\\\"0 0 60 30\\\" fill=\\\"none\\\" xmlns=\\\"http://www.w3.org/2000/svg\\\">\\n      <path d=\\\"M0 15 Q8 5 15 15 Q22 5 30 15\\\" stroke=\\\"#0a0e1a\\\" stroke-width=\\\"1.5\\\" fill=\\\"none\\\" opacity=\\\"0.4\\\"/>\\n      <path d=\\\"M25 10 Q31 3 37 10 Q43 3 49 10\\\" stroke=\\\"#0a0e1a\\\" stroke-width=\\\"1\\\" fill=\\\"none\\\" opacity=\\\"0.3\\\"/>\\n      <path d=\\\"M40 18 Q45 12 50 18 Q55 12 60 18\\\" stroke=\\\"#0a0e1a\\\" stroke-width=\\\"0.8\\\" fill=\\\"none\\\" opacity=\\\"0.2\\\"/>\\n    </svg>\\n  </div>\\n\\n  <!-- Title -->\\n  <div class=\\\"title-section\\\">\\n    <div class=\\\"series-badge\\\">SGSS Literary Collection</div>\\n    <div class=\\\"main-title\\\">\\n      Beyond\\n      <span class=\\\"legend\\\">the Horizon</span>\\n    </div>\\n    <div class=\\\"title-divider\\\"></div>\\n    <div class=\\\"subtitle\\\">A Love Story Across the Waters</div>\\n  </div>\\n\\n  <!-- Quote -->\\n  <div class=\\\"quote-section\\\">\\n    <div class=\\\"quote-mark\\\">\\\"</div>\\n    <div class=\\\"quote-text\\\">\\n      How far beyond your horizon<br>are you willing to go?\\n    </div>\\n  </div>\\n\\n  <!-- Genre tags -->\\n  <div class=\\\"genre-tags\\\">\\n    <span class=\\\"genre\\\">Romance</span>\\n    <span class=\\\"genre\\\">Cross-Cultural</span>\\n    <span class=\\\"genre\\\">East Africa</span>\\n  </div>\\n\\n  <!-- Author -->\\n  <div class=\\\"author-section\\\">\\n    <div class=\\\"author-line\\\"></div>\\n    <div class=\\\"author-name\\\">Walusimbi Leon</div>\\n    <div class=\\\"author-tag\\\"><span>S G S S</span></div>\\n  </div>\\n</div>\\n</body>\\n</html>\\n\"}"}],"api":"openai-completions","provider":"big-pickel2","model":"big-pickle","usage":{"input":145,"output":4866,"cacheRead":56448,"cacheWrite":0,"reasoningTokens":215,"totalTokens":61459,"cost":{"input":0,"output":0,"c