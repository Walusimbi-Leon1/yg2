#!/usr/bin/env bash
# bin/start-git-dashboard — Start the L4 Git Dashboard + auto-commit daemon
# Dashboard on port 3030, auto-commit syncs sessions to repo every 2 min
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PORT="${GIT_DASHBOARD_PORT:-3030}"

# Start auto-commit daemon (syncs sessions + pushes to repo every 2 min)
if [ -x "$SCRIPT_DIR/bin/auto-commit-daemon" ]; then
  "$SCRIPT_DIR/bin/auto-commit-daemon"
fi

# Check if dashboard already running
if lsof -ti :"$PORT" >/dev/null 2>&1; then
  echo "   ✅ Git Dashboard already running on http://127.0.0.1:$PORT"
  exit 0
fi

echo "   🚀 Starting Git Dashboard on port $PORT..."
export GIT_DASHBOARD_WORKSPACE="$SCRIPT_DIR"
nohup node "$SCRIPT_DIR/git-dashboard/server.js" > "$SCRIPT_DIR/git-dashboard/server.log" 2>&1 &
echo "   PID: $!"
echo "   📊 Dashboard: http://127.0.0.1:$PORT"
